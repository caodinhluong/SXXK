# ====================================================
# SXXK Chatbot - Environment Variables
# Copy to .env and fill in the values
# ====================================================

# OpenAI API Key (required)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Admin API Key for file management endpoints
# Change this to a strong secret key
CHATBOT_API_KEY=sxxk-chatbot-secret-key

# LLM Settings (optional - defaults shown)
GENERATE_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536
TEMPERATURE_MAIN=0.6
MAX_GEN_MAIN=600

# Router type: "keyword" (default, no API cost) or "semantic" (needs embeddings)
ROUTER_TYPE=keyword

# Reranker (disabled by default - requires CUDA GPU)
USE_RERANKER=False

# CORS - comma-separated allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000
